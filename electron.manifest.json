{
  "executable": "DexInstructionRunner",
  "splashscreen": {
    "imageFile": ""
  },
  "name": "DexInstructionRunner",
  "author": "",
  "singleInstance": false,
  "environment": "Production",
  "build": {
    "appId": "com.DexInstructionRunner.app",
    "productName": "DexInstructionRunner",
    "copyright": "Copyright © 2020",
    "buildVersion": "1.0.0",
    "compression": "maximum",
    "directories": {
      "output": "../../../bin/Desktop"
    },
    "extraResources": [
      {
        "from": "./bin",
        "to": "bin",
        "filter": [ "**/*" ]
      }
    ],
    "files": [
      {
        "from": "./ElectronHostHook/node_modules",
        "to": "ElectronHostHook/node_modules",
        "filter": [ "**/*" ]
      },
      "**/*"
    ],
    "splashscreen": {
      "imageFile": "./assets/splashscreen.png"
    }

  }
}