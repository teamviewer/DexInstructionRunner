<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FixedAvaloniaAuthApp.ErrorWindow"
        Width="300" Height="150" Title="Error">
	<StackPanel Margin="10" Spacing="10">
		<TextBlock x:Name="ErrorMessage" TextWrapping="Wrap" FontSize="14" />
		<Button Content="OK" HorizontalAlignment="Right" Click="OnOkClicked" />
	</StackPanel>
</Window>
